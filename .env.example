# Copy this file to .env and fill in your values
# cp .env.example .env

# Path to the SQLite database file (default: jobagg.db in current directory)
JOBAGG_DB_PATH=jobagg.db

# User-Agent string sent with every HTTP request.
# Replace with your actual contact email so APIs can reach you if needed.
JOBAGG_USER_AGENT=jobagg/0.1 (+contact: your@email.com)

# Adzuna API credentials — only needed if you use "sync adzuna"
# Register at: https://developer.adzuna.com → My Apps
# Leave empty if you are not using Adzuna.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
